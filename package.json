{
	"name": "@juvofy/lib",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"build": "vite build",
		"preview": "vite preview",
		"postinstall": "vite build",
		"preversion": "pnpm svelte-package -i src"
	},
	"devDependencies": {
		"@sveltejs/package": "^2.5.7",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tsconfig/svelte": "^5.0.8",
		"@types/node": "^25.9.1",
		"oxlint": "^1.66.0",
		"prettier-plugin-svelte": "^4.0.0",
		"svelte-check": "^4.4.8",
		"svelte-eslint-parser": "^1.6.1",
		"typescript": "~6.0.3",
		"vite": "^8.0.14"
	},
	"dependencies": {
		"@material-symbols/svg-400": "^0.44.8",
		"@stanko/dual-range-input": "^1.0.1",
		"@types/common-tags": "^1.8.4",
		"cally": "^0.9.2",
		"common-tags": "^1.8.2",
		"daisyui": "^5.5.20",
		"emoji-picker": "^0.0.7",
		"emoji-picker-element-data": "^1.8.0",
		"fast-xml-parser": "^5.8.0",
		"svelte": "^5.55.9",
		"tailwindcss": "^4.3.0"
	},
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/main.d.ts",
			"import": "./dist/main.js"
		},
		"./components/*": {
			"types": "./dist/components/*.svelte.d.ts",
			"import": "./dist/components/*.svelte"
		},
		"./utils/*": {
			"types": "./dist/utils/*.d.ts",
			"import": "./dist/utils/*.js"
		},
		"./vite/*": {
			"types": "./dist/vite/*.d.ts",
			"import": "./dist/vite/*.js"
		},
		"./app.tw.css": "./dist/app.tw.css",
		"./App": {
			"types": "./dist/App.svelte.d.ts",
			"import": "./dist/App.svelte"
		}
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"peerDependencies": {
		"vite": "^7.3.1"
	}
}
